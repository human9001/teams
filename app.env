#Mysql configuration
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=teams
MYSQL_USER=app
MYSQL_PASSWORD= password
MYSQL_PORT=3306

MYSQL_MIGRATOR_IMAGE=migrate/migrate:v4.17.0

DB_URI=mysql://app:password@tcp(mysql:3306)/teams?multiStatements=true

#App
JWT_SECRET=verysecretkey
JWT_TTL=45m


#Http configuration
HTTP_HOST=localhost
HTTP_PORT=8090
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=5s

#redis
CACHE_ADDR=localhost:6379
CACHE_PASSWORD=""
CACHE_TTL=5m
CACHE_DB=0